Algoritmo SumaCuadrados100

    Definir i, suma Como Entero

    // Inicializamos la variable acumuladora
    suma <- 0

    // Recorremos los 100 primeros números naturales
    Para i <- 1 Hasta 100 Hacer

        // Sumamos el cuadrado de cada número
        suma <- suma + (i * i)

    FinPara

    // Mostramos el resultado
    Escribir "La suma de los cuadrados de los 100 primeros números naturales es: ", suma

FinAlgoritmo
